---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <MainCard
    title="About"
    bgImage={["/image/hbg1.png", "/image/hbg2.jpg", "/image/hbg3.jpg"]}
    bgOverlay={0.25} 
    bgInterval={5000}
    bgTransition={1000}
    infoIcon="lucide:info"
  >
  </MainCard>
    <div class="space-y-10 mb-8">
      <!-- Profile Section -->
      <section class="flex flex-col md:flex-row gap-8 items-center md:items-start">
        <div class="avatar">
          <div
            class="w-32 h-32 md:w-40 md:h-40 rounded-xl ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden"
          >
            <img src="/profile.png" alt="muyufly" width="160" height="160" loading="eager" />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-bold mb-2">muyufly</h1>
          <p class="text-xl text-base-content/80 mb-4">Developer & Open-Source Enthusiast</p>

          <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-6">
            <a
              href="https://github.com/muyufly"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2"
            >
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub</span>
            </a>
            <a
              href="https://x.com/muyuflying"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2"
            >
              <Icon name="lucide:twitter" class="w-4 h-4" />
              <span>Twitter</span>
            </a>
            <a href="mailto:contact.muyuflying@gmail.com" class="btn btn-sm btn-outline gap-2">
              <Icon name="lucide:mail" class="w-4 h-4" />
              <span>Email</span>
            </a>
          </div>

          <p class="text-base-content/80">
            Hello! I'm muyufly, an undergraduate student majored in Software Engineering and Artificial Intelligence.
            Programming is my hobby, and I used to dream of being a extraordinary developer, but now since Vibe Coding
            advancing at the speed of light, I tried to be an AI researcher.
          </p>
        </div>
      </section>

      <!-- GitHub Stats -->
      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          <span>GitHub Statistics</span>
        </h2>

        <GitHubStats username="muyufly" showLanguages={true} showCommitGraph={true} />
      </section>

      <!-- Tech Stack -->
      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:code-2" class="w-6 h-6 text-primary" />
          <span>Tech Stack</span>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {
            [
              { name: "Python", icon: "simple-icons:python", color: "oklch(0.7 0.2 250)" },
              { name: "C++", icon: "simple-icons:cplusplus", color: "oklch(0.6 0.2 240)" },
              { name: "JavaScript", icon: "simple-icons:javascript", color: "oklch(0.8 0.2 80)" },
              { name: "TypeScript", icon: "simple-icons:typescript", color: "oklch(0.6 0.2 250)" },
              { name: "React", icon: "simple-icons:react", color: "oklch(0.7 0.2 200)" },
              { name: "Astro", icon: "simple-icons:astro", color: "oklch(0.5 0.2 300)" },
              { name: "Node.js", icon: "simple-icons:nodedotjs", color: "oklch(0.7 0.2 140)" },
              { name: "TailwindCSS", icon: "simple-icons:tailwindcss", color: "oklch(0.6 0.2 220)" },
              { name: "HTML5", icon: "simple-icons:html5", color: "oklch(0.7 0.2 30)" },
              { name: "CSS3", icon: "simple-icons:css3", color: "oklch(0.7 0.2 220)" },
              { name: "Git", icon: "simple-icons:git", color: "oklch(0.7 0.2 30)" },
              
              { name: "Electron", icon: "simple-icons:electron", color: "oklch(0.6 0.2 160)" },
              
            ].map((tech) => (
              <div class="flex flex-col items-center justify-center p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors">
                <div class="text-3xl mb-2" style={`color: ${tech.color}`}>
                  <Icon name={tech.icon} class="w-10 h-10" />
                </div>
                <span class="text-sm font-medium">{tech.name}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Contribution Activity -->
      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:activity" class="w-6 h-6 text-primary" />
          <span>Recent Activity</span>
        </h2>

        <div class="bg-base-200 rounded-xl p-6 overflow-x-auto">
          <div class="flex flex-col md:flex-row gap-8 md:gap-4 md:overflow-x-auto md:pb-2">
            {
              [
                {
                  date: "March 2026",
                  title: "Project development",
                  desc: "Develop the frontend of ProjectManager",
                },
                {
                  date: "March 2026",
                  title: "Muti-Modal AI Agent development",
                  desc: "Started development of the Muti-Modal AI Agent",
                },
              ].map((item, i) => (
                <div class="relative flex gap-4 pb-2 md:pb-0 md:min-w-[250px]">
                  <div class="flex flex-col items-center">
                    <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-primary-content text-xl">
                      {i + 1}
                    </div>
                    <div class="w-0.5 h-16 bg-base-300 mt-2 md:hidden" />
                  </div>
                  <div>
                    <div class="text-sm text-base-content/60 mb-1">{item.date}</div>
                    <h3 class="text-lg font-bold">{item.title}</h3>
                    <p class="text-base-content/80 mt-1">{item.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
