---
import { Code } from "astro-expressive-code/components";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryGrid from "@/components/widgets/CategoryGrid.astro";
import StarStatsCard from "@/components/widgets/StarStatsCard.astro";

// 这是一个可以在未来随意增加的分类数组，新增分类入口时在这里添加即可
const categories = [
  { name: "Tech", description: "探索最新的技术、开发工具与编程心得", icon: "lucide:terminal" },
  { name: "Life", description: "记录生活点滴，关于旅行、咖啡与随想", icon: "lucide:coffee" },
  { name: "Design", description: "UI/UX 设计心得，提升用户体验的技巧", icon: "lucide:palette" },
  { name: "Tutorials", description: "保姆级教程，带你从零开始掌握新技能", icon: "lucide:book-open" },
  { name: "Open Source", description: "开源世界探索与个人代码贡献经历", icon: "lucide:github" },
  { name: "Resources", description: "精选效率工具软件、字体与网站素材推荐", icon: "lucide:folder-heart" },
];
---

<BaseLayout title="Home">
  <MainCard
    title="Home"
    bgImage={["/image/hbg1.png", "/image/hbg2.jpg", "/image/hbg3.jpg"]}
    bgOverlay={0.25} 
    bgInterval={5000}
    bgTransition={1000}
    infoIcon="lucide:info"
  >
  </MainCard>
      
  <div class="mt-12 px-4 sm:px-0">
    <CategoryGrid 
      categories={categories} 
      title="Discover Topics" 
      subtitle="快速进入你感兴趣的文章分类" 
    />
  </div>

  <div class="mt-8 mb-16 px-4 sm:px-0">
    <StarStatsCard />
  </div>
     
</BaseLayout>
